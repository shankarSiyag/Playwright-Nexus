# =========================================
# PRODUCTION Environment
# =========================================
# NOTE: In real prod usage, USER_PASSWORD / API_KEY below should be
# injected via CI secrets (GitHub Actions secrets, Vault, etc.) and
# referenced here as ${PROD_USER_PASSWORD} style placeholders that your
# CI step resolves before the test run — see config/env.config.ts
# resolvePlaceholders() and .github/workflows/playwright.yml
# =========================================
ENV=prod

# UI
BASE_URL=https://practicetestautomation.com/practice-test-login/

# API
API_BASE_URL=https://reqres.in/api

# Credentials (placeholders resolved from CI secrets in real prod use)
USER_EMAIL=student
USER_PASSWORD=Password123

# API auth (reqres.in demo)
API_KEY=reqres-free-v1
API_USER_EMAIL=eve.holt@reqres.in
API_USER_PASSWORD=cityslicka

# Misc
DEFAULT_TIMEOUT=45000
RETRY_COUNT=3
