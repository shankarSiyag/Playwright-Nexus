# =========================================
# ENV TEMPLATE — copy this to env/<name>.env
# This file IS committed to git. Real env/*.env files are NOT.
# =========================================
ENV=dev

# UI
BASE_URL=https://your-app-url.com

# API
API_BASE_URL=https://api.your-app-url.com

# Credentials
USER_EMAIL=your_user@example.com
USER_PASSWORD=YourPassword123!

# API auth
API_KEY=your-api-key
API_USER_EMAIL=api_user@example.com
API_USER_PASSWORD=ApiPassword123!

# Misc
DEFAULT_TIMEOUT=30000
RETRY_COUNT=1

# For prod, use placeholders that CI resolves from secret storage, e.g.:
# USER_PASSWORD=${PROD_USER_PASSWORD}
# API_KEY=${PROD_API_KEY}
